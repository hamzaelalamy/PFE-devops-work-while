# ============================================
# WorkWhile - Docker Environment Variables
# ============================================
# Copy to .env and fill in production values
# docker compose reads .env from project root

# Required for production - generate secure random strings
# Example: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-at-least-32-chars
JWT_REFRESH_SECRET=your-secure-refresh-secret-at-least-32-chars

# Optional overrides (defaults in docker-compose.yml)
# JWT_EXPIRE=24h
# JWT_REFRESH_EXPIRE=7d
# FRONTEND_URL=http://localhost
# BACKEND_URL=http://localhost:5000
